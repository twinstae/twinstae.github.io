---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('ko-KR', {
  dateStyle: 'long',
  timeStyle: 'short'
}).format(new Date(post.data.date));

const tags = post.data.tags || [];
const isInProgress = tags.includes('작성 중');
---

<article class="card blog-card">
  <a href={`/${post.id}/`} class="card-link">
    <div class="card-body">
      <h3 class="card-title">
        {post.data.title}
        {isInProgress && <span class="wip-badge">🚧</span>}
      </h3>
      <time class="card-date" datetime={post.data.date.toString()}>
        {formattedDate}
      </time>
      <div class="card-tags">
        {tags.map(tag => (
          <span class="hashtag">#{tag}</span>
        ))}
      </div>
      <p class="card-text">{post.data.excerpt}</p>
    </div>
  </a>
</article>

<style>
  .blog-card {
    border-color: var(--border-color) !important;
    background-color: var(--bg-surface);
    transition: background-color var(--transition-slow);
  }

  .card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .card-link:hover {
    color: inherit;
    text-decoration: none;
  }

  .card-body {
    padding: 1.25rem;
  }

  .card-title {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: var(--text-primary);
    line-height: 1.4;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .wip-badge {
    font-size: 1rem;
    flex-shrink: 0;
  }

  .card-date {
    display: block;
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 0.75rem;
  }

  .card-text {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
