---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);

function buildTocTree(headings: MarkdownHeading[]) {
  const tree: Array<{ heading: MarkdownHeading; children: MarkdownHeading[] }> = [];
  let currentH2: { heading: MarkdownHeading; children: MarkdownHeading[] } | null = null;

  for (const heading of headings) {
    if (heading.depth === 2) {
      currentH2 = { heading, children: [] };
      tree.push(currentH2);
    } else if (heading.depth === 3 && currentH2) {
      currentH2.children.push(heading);
    }
  }

  return tree;
}

const tocTree = buildTocTree(tocHeadings);
---

{tocTree.length > 0 && (
  <nav class="toc" aria-label="목차">
    <div class="toc-header">목차</div>
    <ol class="toc-list">
      {tocTree.map(item => (
        <li class="toc-item">
          <a href={`#${item.heading.slug}`} class="toc-link toc-h2">
            {item.heading.text}
          </a>
          {item.children.length > 0 && (
            <ol class="toc-sublist">
              {item.children.map(child => (
                <li class="toc-subitem">
                  <a href={`#${child.slug}`} class="toc-link toc-h3">
                    {child.text}
                  </a>
                </li>
              ))}
            </ol>
          )}
        </li>
      ))}
    </ol>
  </nav>
)}

<style>
  .toc {
    background-color: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: 0.75rem;
    padding: 1.25rem;
    margin: 2rem 0;
    transition: background-color var(--transition-slow), border-color var(--transition-slow);
  }

  .toc-header {
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-color);
    transition: border-color var(--transition-slow), color var(--transition-slow);
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-item {
    margin-bottom: 0.5rem;
  }

  .toc-link {
    display: block;
    color: var(--text-muted);
    text-decoration: none;
    padding: 0.375rem 0.5rem;
    border-radius: 0.25rem;
    transition: color var(--transition-fast), background-color var(--transition-fast);
    line-height: 1.5;
  }

  .toc-link:hover {
    color: var(--primary);
    background-color: var(--bg-surface-hover);
    text-decoration: none;
  }

  .toc-h2 {
    font-size: 0.95rem;
    font-weight: 500;
  }

  .toc-sublist {
    list-style: none;
    padding-left: 0.75rem;
    margin: 0.25rem 0 0;
  }

  .toc-subitem {
    margin-bottom: 0.25rem;
  }

  .toc-h3 {
    font-size: 0.85rem;
  }
</style>
