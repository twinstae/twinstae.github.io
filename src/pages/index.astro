---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import BlogCard from '../components/BlogCard.astro';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => !post.data.tags?.includes('작성 중'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const allTags = [...new Set(posts.flatMap(post => post.data.tags || []))];
---

<Layout title="진리의 배 조선소" description="탐정토끼가 만드는 진리의 배 블로그">
  <section class="hero">
    <div class="hero-content">
      <img
        class="hero-avatar"
        src="/TamjungRabbitProfile.jpg"
        alt="갈색 코트를 입은 디즈니식 토끼 그림. 주토피아가 탐정물로 기획되던 시절 주인공 주디의 디자인이다."
        width="128"
        height="128"
      />
      <h1 class="hero-title">진리의 배 조선소</h1>
      <p class="hero-subtitle">탐정토끼 (본체: Taehee Kim)</p>
      <p class="hero-description">
        진리의 배는 서로 다른 사람들이 함께 나아가기 위한 플랫폼입니다. 
        그 시작으로 작은 배를 만드는 조선소로서, 이 블로그를 만들었습니다.
      </p>
    </div>
  </section>

  <section class="blog-section">
    <div class="section-header">
      <h2>글 목록</h2>
      <span class="post-count">{posts.length}개의 글</span>
    </div>
    
    <div class="blog-grid">
      {posts.map(post => (
        <BlogCard post={post} />
      ))}
    </div>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 2rem 0 3rem;
    margin-bottom: 2rem;
    border-bottom: 2px solid var(--border-color);
    transition: border-color var(--transition-slow);
  }

  .hero-avatar {
    width: 8rem;
    height: 8rem;
    border-radius: 50%;
    object-fit: cover;
    margin: 0 auto 1.5rem;
    box-shadow: var(--shadow-md);
    border: 3px solid var(--border-color);
    transition: border-color var(--transition-slow);
  }

  .hero-title {
    font-size: 2.5rem;
    margin: 0 0 0.5rem;
    color: var(--primary);
  }

  .hero-subtitle {
    font-size: 1.125rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .hero-description {
    max-width: 600px;
    margin: 0 auto;
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.8;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .section-header h2 {
    margin: 0;
    border: none;
    padding: 0;
  }

  .post-count {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .hero {
      padding: 3rem 0 4rem;
    }

    .hero-title {
      font-size: 3rem;
    }
  }
</style>
